# server/.env.template — Copy to server/.env and fill secrets
# Keep real secrets out of version control.

# Server runtime
PORT=3001
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Groq AI
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Google Cloud
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key
# Optionally provide the full service account JSON as a Render secret and reference it via GOOGLE_APPLICATION_CREDENTIALS_JSON
GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account",...}'

# Cloudinary (server-side)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# Firebase Admin (if used)
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Other keys
OPENAI_API_KEY=your_openai_api_key

# Note: On Render, set these as "Secret" environment variables via the Dashboard or API.
