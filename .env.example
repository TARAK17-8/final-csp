# ═══════════════════════════════════════════════════════════════
# samaramAI — Environment Variables Template
# ═══════════════════════════════════════════════════════════════
#
# Deployment Architecture:
#   Frontend → Netlify  (set VITE_* vars in Netlify Dashboard)
#   Backend  → Render   (set server vars in Render Dashboard)
#
# For local development, copy this to:
#   client/.env   (frontend vars)
#   server/.env   (backend vars)
# ═══════════════════════════════════════════════════════════════

# === Frontend (prefix with VITE_) ===

# Firebase Configuration (Auth, Firestore, Storage)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Backend API URL
# For local development:
VITE_API_URL=/api
# For production (Render):
# VITE_API_URL=https://samaramai-api.onrender.com

# Cloudinary (image uploads)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# === Backend ===
PORT=3001
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Groq AI
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Google Cloud Vision API
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key

# Cloudinary (server-side)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
